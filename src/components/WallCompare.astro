---
// "Печать на стене" vs "Обои" comparison — recreated from the client's WallPrint
// infographic (Wall Pixels branding dropped). Icons are inline SVG (all <path>).
const good = [
  { t: "Любая поверхность", d: "Ложится и на гладкие, и на фактурные стены.", icon: ["M4 6h16v12H4z", "M4 12h16", "M10 6v6", "M16 6v6", "M7 12v6", "M13 12v6"] },
  { t: "Не отслаивается", d: "Держится прочно — не отходит и не пузырится.", icon: ["M12 3l7 3v5c0 4.5-3 7.6-7 8.6-4-1-7-4.1-7-8.6V6z", "M8.5 12l2.5 2.5 4.5-4.5"] },
  { t: "Мгновенно сохнет", d: "Высыхает сразу — быстро и без хлопот.", icon: ["M12 4a8 8 0 1 0 0 16 8 8 0 1 0 0-16", "M12 8v4l3 2"] },
  { t: "Чисто", d: "Аккуратная работа без грязи и пыли.", icon: ["M11 3l1.6 4.6L17 9l-4.4 1.4L11 15l-1.6-4.6L5 9l4.4-1.4z", "M17.5 14l.8 2.2 2.2.8-2.2.8-.8 2.2-.8-2.2-2.2-.8z"] },
  { t: "Почти без запаха", d: "Лёгкий запах — комфортно находиться рядом.", icon: ["M4 9h9a2.5 2.5 0 1 0-2.5-2.5", "M4 13h13a2.5 2.5 0 1 1-2.5 2.5", "M4 17h6"] },
  { t: "Прочно и влагостойко", d: "Не боится влаги и служит годами.", icon: ["M12 3l7 3v5c0 4.5-3 7.6-7 8.6-4-1-7-4.1-7-8.6V6z", "M12 9.5c1.5 1.9 2.5 3 2.5 4.3a2.5 2.5 0 0 1-5 0c0-1.3 1-2.4 2.5-4.3z"] },
  { t: "Точно по стене", d: "Печатаем под размер стены — без швов и подгонки.", icon: ["M4 9V4h5", "M20 9V4h-5", "M4 15v5h5", "M20 15v5h-5"] },
];
const bad = [
  { t: "Только гладкие стены", d: "Хорошо ложатся лишь на ровную поверхность.", icon: ["M8 4h9v13a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7", "M8 4a3 3 0 0 0-3 3h4"] },
  { t: "Отклеиваются", d: "Со временем отходят, особенно по краям.", icon: ["M9 4h10v10H9z", "M5 9h10v10H5z"] },
  { t: "Долго клеить", d: "Требуют времени и аккуратности при поклейке.", icon: ["M7 4h10", "M7 20h10", "M8 4c0 4 8 5 8 8s-8 4-8 8", "M16 4c0 4-8 5-8 8s8 4 8 8"] },
  { t: "Нужны материалы", d: "Клей, кисти и дополнительные инструменты.", icon: ["M10 3h4v3h-4z", "M9 6h6l1 3v10a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V9z"] },
  { t: "Резкий запах", d: "Клей и бумага могут сильно пахнуть.", icon: ["M8 21h8", "M9.5 21c0-3-2-4-2-7s2-3 2-6", "M12 21c0-3-2-4-2-7s2-3 2-6", "M14.5 21c0-3-2-4-2-7s2-3 2-6"] },
  { t: "Боятся влаги", d: "Выцветают и портятся во влажных помещениях.", icon: ["M11 3c3.2 4.2 5 6.5 5 9a5 5 0 0 1-10 0c0-2.5 1.8-4.8 5-9z", "M18 13c1 1.3 1.5 2.1 1.5 2.8a1.5 1.5 0 0 1-3 0c0-.7.5-1.5 1.5-2.8z"] },
  { t: "Видны швы", d: "После поклейки заметны стыки между полосами.", icon: ["M4 4h16v16H4z", "M12 4v16", "M4 12h16"] },
];
---

<section class="section vs-section" id="sravnenie">
  <div class="wrap">
    <div style="text-align:center;margin-bottom:38px;">
      <p class="eyebrow center reveal">Печать и обои</p>
      <h2 class="h-section reveal" style="margin-top:14px;">Печать или обои — в чём разница</h2>
    </div>

    <div class="vs reveal">
      <span class="vs-badge">VS</span>
      <div class="vs-body">
        <div class="vs-col">
          <div class="vs-title">Печать на стене</div>
          {good.map((i) => (
            <div class="vs-row">
              <span class="vs-ic good"><svg viewBox="0 0 24 24">{i.icon.map((d) => <path d={d} />)}</svg></span>
              <div class="vs-txt"><b>{i.t}</b><p>{i.d}</p></div>
            </div>
          ))}
        </div>
        <div class="vs-col vs-col-bad">
          <div class="vs-title bad">Обои и фотообои</div>
          {bad.map((i) => (
            <div class="vs-row">
              <div class="vs-txt"><b>{i.t}</b><p>{i.d}</p></div>
              <span class="vs-ic bad"><svg viewBox="0 0 24 24">{i.icon.map((d) => <path d={d} />)}</svg></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
