---
// Procedural graffiti spray-paint splatter (deterministic per seed).
interface Props { color?: string; seed?: number; class?: string; opacity?: number; style?: string; }
const { color = "#cde221", seed = 1, class: cls = "", opacity = 1, style = "" } = Astro.props;

function mulberry32(a: number) {
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rnd = mulberry32((seed * 2654435761) >>> 0);
const W = 600, H = 460, cx = W * 0.5, cy = H * 0.44;

// soft paint pool (overlapping blobs near centre)
const blobs = Array.from({ length: 6 }, () => {
  const ang = rnd() * Math.PI * 2;
  const d = rnd() * W * 0.16;
  return { x: cx + Math.cos(ang) * d, y: cy + Math.sin(ang) * d * 0.8, r: 30 + rnd() * 44 };
});
// scattered spray dots (density falls off from centre)
const dots = Array.from({ length: 70 }, () => {
  const ang = rnd() * Math.PI * 2;
  const dist = Math.pow(rnd(), 0.55) * W * 0.46;
  const x = cx + Math.cos(ang) * dist;
  const y = cy + Math.sin(ang) * dist * 0.72;
  const r = 0.8 + rnd() * (dist < W * 0.16 ? 7 : 3.4);
  const o = Math.max(0.12, 0.75 * (1 - dist / (W * 0.5)));
  return { x, y, r, o };
});
// a few drips hanging below
const drips = Array.from({ length: 5 }, () => {
  const x = cx + (rnd() - 0.5) * W * 0.6;
  const y = cy + H * 0.16 + rnd() * 26;
  const len = 14 + rnd() * 52;
  const r = 2.2 + rnd() * 3.4;
  return { x, y, len, r };
});
---
<svg class={`spray ${cls}`} viewBox={`0 0 ${W} ${H}`} fill={color} style={`opacity:${opacity};${style}`} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
  {blobs.map((b) => <circle cx={b.x} cy={b.y} r={b.r} opacity="0.5" />)}
  {dots.map((d) => <circle cx={d.x} cy={d.y} r={d.r} opacity={d.o} />)}
  {drips.map((d) => (
    <g>
      <rect x={d.x - d.r / 2} y={d.y} width={d.r} height={d.len} rx={d.r / 2} opacity="0.55" />
      <circle cx={d.x} cy={d.y + d.len} r={d.r * 1.25} opacity="0.55" />
    </g>
  ))}
</svg>
